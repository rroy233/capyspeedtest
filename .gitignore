# Merged from official GitHub templates:
# - https://raw.githubusercontent.com/github/gitignore/main/Node.gitignore
# - https://raw.githubusercontent.com/github/gitignore/main/Rust.gitignore
# TypeScript note:
# - github/gitignore currently has no standalone TypeScript.gitignore;
#   TypeScript-related ignores are covered by Node.gitignore (e.g. *.tsbuildinfo).

# Node.js / TypeScript
node_modules/
jspm_packages/
web_modules/
.npm/
.pnpm-store/
.nyc_output/
coverage/
*.tsbuildinfo
.eslintcache
.stylelintcache
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.vite/
dist/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# Env files
.env
.env.*
!.env.example

# Rust / Cargo
debug/
target/
src-tauri/target/
**/*.rs.bk
*.pdb
**/mutants.out*/

# IDE / local tools
.vscode/
.vscode-test/
.idea/
.trae/
.claude/

# OS files
.DS_Store
Thumbs.db

# Local reference workspace
ref_project/

