{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "CapySpeedtest",
  "version": "0.1.0",
  "identifier": "com.roy233.capyspeedtest",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CapySpeedtest",
        "width": 980,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyRDJFNzVCNDFDMjAyQzYKUldUR0FzSkJXK2ZTUWdvb05OYnpIYnQrVXBSTVl0aklMQ3gxZW9TMlgxMVNWdVhvTkRHaWdlU2UK",
      "endpoints": [
        "https://github.com/rroy233/capyspeedtest/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
